{
  "functions": {
    "api/analyze.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/speak.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/analyze", "destination": "/api/analyze" },
    { "source": "/api/speak", "destination": "/api/speak" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
